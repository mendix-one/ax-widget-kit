{
  "name": "ax-widget-kit-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "AX Widget Kit Monorepo",
  "author": "Danniel Ng",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=16"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "vite": "vite",
    "build:all": "npm run build --workspaces",
    "dev:auth-layout": "npm run dev -w @ax/auth-layout",
    "dev:signin-form": "npm run dev -w @ax/signin-form",
    "dev:signup-form": "npm run dev -w @ax/signup-form",
    "dev:resetpsw-form": "npm run dev -w @ax/resetpsw-form",
    "dev:setpsw-form": "npm run dev -w @ax/setpsw-form",
    "build:auth-layout": "npm run build -w @ax/auth-layout",
    "build:signin-form": "npm run build -w @ax/signin-form",
    "build:signup-form": "npm run build -w @ax/signup-form",
    "build:resetpsw-form": "npm run build -w @ax/resetpsw-form",
    "build:setpsw-form": "npm run build -w @ax/setpsw-form",
    "lint": "npm run lint --workspaces",
    "lint:fix": "npm run lint:fix --workspaces",
    "format": "prettier --write \"./**/*.{js,jsx,ts,tsx,json,css,scss,xml}\""
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^9.39.1",
    "@fontsource/roboto": "^5.2.9",
    "@mui/icons-material": "^7.3.7",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.3.7",
    "@prettier/plugin-xml": "^3.4.2",
    "@svgdotjs/svg.js": "^3.2.5",
    "@types/big.js": "^6.0.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-dom": "^2.12.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-react-x": "^2.12.2",
    "globals": "^16.5.0",
    "i18next": "^25.10.9",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "prettier": "^3.8.1",
    "react-i18next": "^16.6.6",
    "react-router": "^7.13.0",
    "sass": "^1.97.3",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  },
  "overrides": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0"
  }
}
