<?xml version="1.0" encoding="utf-8"?>
<widget id="mendixone.axwidgetkit.AXAuthPage" pluginWidget="true" needsEntityContext="true" offlineCapable="true"
        supportedPlatform="Web"
        xmlns="http://www.mendix.com/widget/1.0/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>AXAuth Page</name>
    <description>Authentication page widget with Sign In, Sign Up, and Reset Password forms</description>
    <icon/>
    <properties>
        <propertyGroup caption="General">
            <propertyGroup caption="Page">
                <property key="page" type="enumeration" defaultValue="signIn">
                    <caption>Page type</caption>
                    <description>Which authentication form to display</description>
                    <enumerationValues>
                        <enumerationValue key="signIn">Sign In</enumerationValue>
                        <enumerationValue key="signUp">Sign Up</enumerationValue>
                        <enumerationValue key="resetPass">Reset Password</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="showSSO" type="boolean" defaultValue="true">
                    <caption>Show SSO buttons</caption>
                    <description>Show Google and Microsoft SSO buttons</description>
                </property>
            </propertyGroup>
            <propertyGroup caption="Form data">
                <property key="emailAttr" type="attribute" required="false">
                    <caption>Email</caption>
                    <description>Attribute to bind the email field</description>
                    <attributeTypes>
                        <attributeType name="String"/>
                    </attributeTypes>
                </property>
                <property key="passwordAttr" type="attribute" required="false">
                    <caption>Password</caption>
                    <description>Attribute to bind the password field</description>
                    <attributeTypes>
                        <attributeType name="String"/>
                    </attributeTypes>
                </property>
                <property key="fullNameAttr" type="attribute" required="false">
                    <caption>Full name</caption>
                    <description>Attribute to bind the full name field (Sign Up only)</description>
                    <attributeTypes>
                        <attributeType name="String"/>
                    </attributeTypes>
                </property>
            </propertyGroup>
            <propertyGroup caption="Branding">
                <property key="tagline" type="textTemplate" required="false">
                    <caption>Tagline</caption>
                    <description>Heading text displayed on the left panel</description>
                </property>
                <property key="brandDescription" type="textTemplate" required="false">
                    <caption>Description</caption>
                    <description>Description text below the tagline</description>
                </property>
            </propertyGroup>
        </propertyGroup>
        <propertyGroup caption="Events">
            <property key="onSubmit" type="action" required="false">
                <caption>On submit</caption>
                <description>Action to execute when the form is submitted</description>
            </property>
            <property key="onNavigateSignIn" type="action" required="false">
                <caption>On navigate to Sign In</caption>
                <description>Action when user clicks link to Sign In page</description>
            </property>
            <property key="onNavigateSignUp" type="action" required="false">
                <caption>On navigate to Sign Up</caption>
                <description>Action when user clicks link to Sign Up page</description>
            </property>
            <property key="onNavigateResetPass" type="action" required="false">
                <caption>On navigate to Reset Password</caption>
                <description>Action when user clicks link to Reset Password page</description>
            </property>
            <property key="onGoogleSSO" type="action" required="false">
                <caption>On Google SSO</caption>
                <description>Action when user clicks the Google SSO button</description>
            </property>
            <property key="onMicrosoftSSO" type="action" required="false">
                <caption>On Microsoft SSO</caption>
                <description>Action when user clicks the Microsoft SSO button</description>
            </property>
        </propertyGroup>
    </properties>
</widget>
