{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.simulation.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /* Path aliases for widget packages */
    "paths": {
      "@ax/shared": ["./packages/ax-shared/src"],
      "@ax/shared/*": ["./packages/ax-shared/src/*"],
      "@ax/auth-layout/*": ["./packages/ax-auth-layout/*"],
      "@ax/signin-form/*": ["./packages/ax-signin-form/*"],
      "@ax/signup-form/*": ["./packages/ax-signup-form/*"],
      "@ax/resetpsw-form/*": ["./packages/ax-resetpsw-form/*"],
      "@ax/setpsw-form/*": ["./packages/ax-setpsw-form/*"],
      "@ax/web-app/*": ["./packages/ax-web-app/*"],
      "@ax/logo/*": ["./packages/ax-logo/*"],
      "@ax/tasks-menu/*": ["./packages/ax-tasks-menu/*"],
      "@ax/notify-menu/*": ["./packages/ax-notify-menu/*"],
      "@ax/user-menu/*": ["./packages/ax-user-menu/*"],
      "@ax/sidebar/*": ["./packages/ax-sidebar/*"],
      "@ax/agent-chat/*": ["./packages/ax-agent-chat/*"],
      "@ax/text-field/*": ["./packages/ax-text-field/*"],
      "@ax/button/*": ["./packages/ax-button/*"],
      "@ax/button-group/*": ["./packages/ax-button-group/*"],
      "@ax/checkbox/*": ["./packages/ax-checkbox/*"],
      "@ax/radio-group/*": ["./packages/ax-radio-group/*"],
      "@ax/select/*": ["./packages/ax-select/*"],
      "@ax/slider/*": ["./packages/ax-slider/*"],
      "@ax/switch/*": ["./packages/ax-switch/*"],
      "@ax/toggle-button/*": ["./packages/ax-toggle-button/*"]
    }
  },
  "include": ["simulation"],
  "exclude": ["node_modules", "dist", "sample"]
}
